  "components": {
    "schemas": {
      "AnalyzeQueryRequest": {
        "properties": {
          "query": {
            "type": "string",
            "maxLength": 120,
            "title": "Query",
            "description": "自然语言查询，如'帮我看看建科智能怎么样'，限120字"
          },
          "session_id": {
