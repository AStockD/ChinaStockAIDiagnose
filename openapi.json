    "/analyze/portfolio": {
      "post": {
        "tags": [
          "AI分析-策略"
        ],
        "summary": "Portfolio Analysis Service",
        "description": "组合持仓分析：输入持仓成本和数量，返回组合级 + 逐股分析报告\n\n对每只持仓执行完整分析流水线（技术指标+资金流+OHLCV+斐波那契），\n然后聚合组合级指标（总市值、盈亏、集中度、风险等级），\n最后由 LLM 生成包含具体参考价位的组合分析报告。\n\n报告包含免责声明，仅供参考，不构成投资建议。",
        "operationId": "portfolio_analysis_service_analyze_portfolio_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PortfolioRequest"
              }
            }
          },
          "required": true
